# Base URL of your Oracle APEX REST API (no trailing slash).
# Default if unset: http://localhost:8080/ords/api
# Example for cloud: https://your-instance.adb.us-ashburn-1.oraclecloudapps.com/ords/yourworkspace/api
VITE_ORACLE_APEX_URL=http://localhost:8080/ords/api

# Oracle APEX login page URL (optional). If unset, derived from ORACLE_APEX_URL + /ords/f?p=4550:LOGIN
# Set this if your workspace uses a different login page (e.g. /ords/f?p=WORKSPACE:LOGIN)
# VITE_ORACLE_LOGIN_URL=https://your-instance/ords/f?p=4550:LOGIN
